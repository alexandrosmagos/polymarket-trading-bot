# Copy targets (comma-separated list of addresses or usernames)
# Insider targets: copy all qualifying trades from these users
COPY_TARGET_USER=0x63ce342161250d705dc0b16df89036c8e5f9ba9a,0xAnotherAddressHere

# Whale targets: high-volume traders — format: address:minUsd (per-user threshold)
# Example: 0xABCD...:100,0xDEAD...:500,0xBEEF...:25
COPY_WHALE_USERS=

COPY_POLL_INTERVAL_MS=15000
COPY_ACTIVITY_LIMIT=100
COPY_SIZE_MULTIPLIER=1
COPY_MAX_ORDER_USD=100
COPY_DYNAMIC_AMOUNT=true
COPY_TRADES_ONLY=true

# Pushover Notifications
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# Your wallet (EOA private key + Polymarket proxy/funder address from the UI)
POLYMARKET_PRIVATE_KEY=..
POLYMARKET_ADDRESS=0x...
# Optional: omitted → proxy+EOA is auto-detected (SIGNATURE_TYPE 1). Override if needed:
# POLYMARKET_SIGNATURE_TYPE=1
# POLYMARKET_SIGNATURE_TYPE=2
# POLYMARKET_CHAIN_ID=137
